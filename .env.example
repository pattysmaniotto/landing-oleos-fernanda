# ============================================
# CONFIGURAÇÃO — LANDING ÓLEOS FERNANDA
# Copie este arquivo para `.env` e preencha os valores
# ============================================

# ----- GMAIL (pra enviar alerta de pedido novo) -----
# Seu Gmail (vai ser o remetente do email)
GMAIL_USER=seuemail@gmail.com

# Senha de app do Gmail (NÃO é a senha normal!)
# Gere em: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# Email que vai RECEBER o alerta (pode ser o mesmo do remetente)
EMAIL_DESTINO=seuemail@gmail.com

# ----- GOOGLE SHEETS (pra salvar os pedidos) -----
# ID da planilha (pega na URL: docs.google.com/spreadsheets/d/ESSE_CODIGO/edit)
GOOGLE_SHEET_ID=

# Caminho pro arquivo de credenciais (mantenha credentials.json na mesma pasta)
GOOGLE_CREDENTIALS_PATH=credentials.json

# ----- SERVIDOR -----
# Porta (Render define sozinho, deixa 5000 pra testes locais)
PORT=5000

# Modo debug (True só pra desenvolvimento local, False em produção)
DEBUG=False
